// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  BUSINESS
  STUDENT
  RETIRED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ReportType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NotificationType {
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ── Finance Enums ─────────────────────────────

enum AccountType {
  SAVINGS
  CURRENT
  WALLET
  CREDIT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum IncomeCategory {
  SALARY
  BUSINESS
  RENTAL
  FREELANCE
  INTEREST
  DIVIDEND
  PENSION
  OTHER
}

enum IncomeFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum ExpenseCategory {
  FOOD
  TRAVEL
  SHOPPING
  MEDICAL
  RENT
  UTILITIES
  EDUCATION
  ENTERTAINMENT
  INVESTMENT
  EMI
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  CHEQUE
  OTHER
}

enum AssetType {
  CASH
  SAVINGS
  FIXED_DEPOSIT
  PROPERTY
  VEHICLE
  GOLD
  STOCKS
  CRYPTO
  OTHER
}

enum LoanType {
  HOME
  CAR
  EDUCATION
  PERSONAL
  BUSINESS
  OTHER
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

enum InvestmentType {
  STOCKS
  MUTUAL_FUND
  ETF
  NPS
  PPF
  FIXED_DEPOSIT
  CRYPTO
  OTHER
}

enum InsuranceType {
  HEALTH
  LIFE
  VEHICLE
  TRAVEL
  HOME
  OTHER
}

enum GoalType {
  EMERGENCY_FUND
  HOUSE
  CAR
  MARRIAGE
  EDUCATION
  VACATION
  RETIREMENT
  OTHER
}

enum ScoreGrade {
  A_PLUS
  A
  B
  C
  D
  E
}

enum RiskLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─────────────────────────────────────────────
// PHASE 4 — AUTH MODELS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  fullName            String
  email               String    @unique
  password            String

  phone               String?   @unique
  role                UserRole  @default(USER)

  isVerified          Boolean   @default(false)
  isActive            Boolean   @default(true)

  emailVerifiedAt     DateTime?
  lastLogin           DateTime?

  refreshToken        String?
  refreshTokenExpiry  DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  profile             UserProfile?
  financialAccounts   FinancialAccount[]
  incomes             Income[]
  expenses            Expense[]
  assets              Asset[]
  loans               Loan[]
  investments         Investment[]
  insurances          Insurance[]
  retirement          Retirement?
  financialGoals      FinancialGoal[]
  scoreHistories      ScoreHistory[]
  aiRecommendations   AIRecommendation[]
  aiForecasts         AIForecast[]
  aiSimulations       AISimulation[]
  aiConversations     AIConversation[]
  aiAuditLogs         AIAuditLog[]
  notifications       Notification[]
  reports             Report[]
}

model UserProfile {
  id              String          @id @default(cuid())
  userId          String          @unique

  gender          Gender?
  dateOfBirth     DateTime?
  employmentType  EmploymentType?
  annualIncome    Decimal?        @db.Decimal(15, 2)
  monthlyIncome   Decimal?        @db.Decimal(15, 2)

  profileImage    String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  country         String?
  postalCode      String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PHASE 5 — FINANCE MODELS
// ─────────────────────────────────────────────

model FinancialAccount {
  id              String        @id @default(cuid())
  userId          String
  bankName        String
  accountName     String
  accountNumber   String?
  accountType     AccountType   @default(SAVINGS)
  currency        String        @default("INR")
  openingBalance  Decimal       @default(0) @db.Decimal(15, 2)
  currentBalance  Decimal       @default(0) @db.Decimal(15, 2)
  status          AccountStatus @default(ACTIVE)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes         Income[]
  expenses        Expense[]
}

model Income {
  id          String          @id @default(cuid())
  userId      String
  accountId   String?
  source      String
  category    IncomeCategory  @default(SALARY)
  amount      Decimal         @db.Decimal(15, 2)
  frequency   IncomeFrequency @default(MONTHLY)
  startDate   DateTime?
  endDate     DateTime?
  notes       String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model Expense {
  id            String          @id @default(cuid())
  userId        String
  accountId     String?
  title         String
  category      ExpenseCategory @default(OTHER)
  amount        Decimal         @db.Decimal(15, 2)
  paymentMethod PaymentMethod   @default(CASH)
  expenseDate   DateTime        @default(now())
  notes         String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model Asset {
  id              String    @id @default(cuid())
  userId          String
  name            String
  assetType       AssetType @default(OTHER)
  purchaseValue   Decimal   @db.Decimal(15, 2)
  currentValue    Decimal   @db.Decimal(15, 2)
  purchaseDate    DateTime?
  description     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Loan {
  id                String     @id @default(cuid())
  userId            String
  loanType          LoanType   @default(PERSONAL)
  lenderName        String
  principalAmount   Decimal    @db.Decimal(15, 2)
  interestRate      Decimal    @db.Decimal(5, 2)
  emiAmount         Decimal    @db.Decimal(15, 2)
  remainingBalance  Decimal    @db.Decimal(15, 2)
  startDate         DateTime
  endDate           DateTime?
  nextEmiDate       DateTime?
  status            LoanStatus @default(ACTIVE)
  notes             String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Investment {
  id              String         @id @default(cuid())
  userId          String
  name            String
  investmentType  InvestmentType @default(OTHER)
  quantity        Decimal?       @db.Decimal(15, 4)
  buyPrice        Decimal        @db.Decimal(15, 2)
  currentPrice    Decimal        @db.Decimal(15, 2)
  broker          String?
  purchaseDate    DateTime?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Insurance {
  id            String        @id @default(cuid())
  userId        String
  insuranceType InsuranceType @default(HEALTH)
  provider      String
  policyNumber  String?
  premiumAmount Decimal       @db.Decimal(15, 2)
  coverageAmount Decimal      @db.Decimal(15, 2)
  startDate     DateTime
  expiryDate    DateTime?
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Retirement {
  id                    String   @id @default(cuid())
  userId                String   @unique
  targetRetirementAge   Int      @default(60)
  currentAge            Int
  currentSavings        Decimal  @db.Decimal(15, 2)
  targetCorpus          Decimal  @db.Decimal(15, 2)
  monthlyContribution   Decimal  @db.Decimal(15, 2)
  expectedReturnRate    Decimal  @db.Decimal(5, 2)
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinancialGoal {
  id              String     @id @default(cuid())
  userId          String
  goalType        GoalType   @default(OTHER)
  title           String
  targetAmount    Decimal    @db.Decimal(15, 2)
  currentAmount   Decimal    @default(0) @db.Decimal(15, 2)
  deadline        DateTime?
  priority        Int        @default(1)
  status          GoalStatus @default(ACTIVE)
  notes           String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PHASE 6 — FINT SCORE ENGINE
// ─────────────────────────────────────────────

model ScoreHistory {
  id            String       @id @default(cuid())
  userId        String
  score         Int
  grade         ScoreGrade
  risk          RiskLevel
  calculatedAt  DateTime     @default(now())
  createdAt     DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  factors       ScoreFactor[]
}

model ScoreFactor {
  id              String       @id @default(cuid())
  scoreHistoryId  String
  pillar          String
  weight          Int
  score           Int
  remarks         String?

  scoreHistory    ScoreHistory @relation(fields: [scoreHistoryId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PHASE 7 — AI ENGINE
// ─────────────────────────────────────────────

model AIRecommendation {
  id              String    @id @default(cuid())
  userId          String
  summary         String
  riskLevel       String
  recommendations Json
  nextSteps       Json
  score           Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AIForecast {
  id               String    @id @default(cuid())
  userId           String
  futureValue      Decimal   @db.Decimal(15, 2)
  retirementCorpus Decimal   @db.Decimal(15, 2)
  savingRate       Decimal   @db.Decimal(5, 2)
  debtRatio        Decimal   @db.Decimal(5, 2)
  summary          String
  risk             String
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AISimulation {
  id           String    @id @default(cuid())
  userId       String
  scenarioType String
  oldScore     Int
  newScore     Int
  scenario     Json
  summary      String
  impact       String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([scenarioType])
}

model AIConversation {
  id        String    @id @default(cuid())
  userId    String
  question  String
  answer    String
  tokens    Int       @default(0)
  provider  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
}

model AIAuditLog {
  id           String    @id @default(cuid())
  userId       String
  action       String
  provider     String
  status       String
  responseTime Float
  tokenUsage   Int
  cost         Decimal?  @db.Decimal(10, 6)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType   @default(EMAIL)
  title     String
  message   String
  status    NotificationStatus @default(PENDING)
  isRead    Boolean            @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Report {
  id          String     @id @default(cuid())
  userId      String
  reportType  ReportType @default(MONTHLY)
  periodStart DateTime
  periodEnd   DateTime
  summary     Json
  generatedAt DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([generatedAt])
}
