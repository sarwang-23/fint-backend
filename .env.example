# ─────────────────────────────────────────────────────────────────────
# FINT Backend — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/fint_db"
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# ── Authentication ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── AI Provider ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
AI_PROVIDER=gemini

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── Object Storage (S3/GCS) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fint-uploads
AWS_REGION=ap-south-1

# ── Monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── AI Cost Budget Alert ──────────────────────────────────────────────
AI_DAILY_BUDGET_USD=5.0
AI_BUDGET_ALERT_THRESHOLD=0.8
